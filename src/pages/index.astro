---
const posts = [
  {
    title: "첫 번째 블로그 글",
    description:
      "새로운 macOS 스타일 블로그를 시작합니다. 개발 공부와 프로젝트, 일상을 기록할 예정입니다.",
    date: "2026.07.18",
    category: "Blog",
    href: "/posts/first-post/",
  },
  {
    title: "Astro로 블로그 만들기",
    description:
      "기존 테마를 벗어나 Astro로 직접 설계하는 과정을 정리합니다.",
    date: "2026.07.18",
    category: "Development",
    href: "/posts/astro-blog/",
  },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />
    <meta
      name="description"
      content="개발과 일상을 기록하는 macOS 스타일 블로그"
    />
    <title>hiJay97</title>
  </head>

  <body>
    <div class="desktop">
      <main class="window">
        <header class="toolbar">
          <div class="traffic-lights" aria-hidden="true">
            <span class="traffic red"></span>
            <span class="traffic yellow"></span>
            <span class="traffic green"></span>
          </div>

          <div class="toolbar-title">
            <span class="folder-icon">📁</span>
            <span>hiJay97</span>
          </div>

          <button
            class="theme-toggle"
            type="button"
            aria-label="라이트 모드와 다크 모드 전환"
            title="테마 변경"
          >
            ◐
          </button>
        </header>

        <div class="window-body">
          <aside class="sidebar">
            <section class="profile">
              <div class="avatar" aria-label="프로필 이미지">
                J
              </div>

              <h1>hiJay97</h1>
              <p>개발과 일상을 기록하는 공간</p>
            </section>

            <nav class="navigation" aria-label="주요 메뉴">
              <a class="active" href="/">
                <span aria-hidden="true">⌂</span>
                Home
              </a>

              <a href="#blog">
                <span aria-hidden="true">▤</span>
                Blog
              </a>

              <a href="#projects">
                <span aria-hidden="true">⌘</span>
                Projects
              </a>

              <a href="#about">
                <span aria-hidden="true">◉</span>
                About
              </a>
            </nav>

            <div class="sidebar-footer">
              <a
                href="https://github.com/97jay181"
                target="_blank"
                rel="noreferrer"
              >
                GitHub ↗
              </a>
            </div>
          </aside>

          <section class="content">
            <header class="content-header">
              <div>
                <span class="eyebrow">Welcome</span>

                <h2>
                  생각과 경험을<br />
                  기록하는 공간.
                </h2>

                <p>
                  개발, 프로젝트, 도구와 일상에 대한 기록을 남깁니다.
                </p>
              </div>

              <label class="search" for="searchInput">
                <span aria-hidden="true">⌕</span>

                <input
                  id="searchInput"
                  type="search"
                  placeholder="Spotlight Search"
                  autocomplete="off"
                  aria-label="게시글 검색"
                />
              </label>
            </header>

            <section class="section" id="blog">
              <div class="section-heading">
                <div>
                  <span class="section-label">Latest</span>
                  <h3>최근 게시글</h3>
                </div>

                <a href="#blog">전체 보기 →</a>
              </div>

              <div class="post-grid" id="postGrid">
                {
                  posts.map((post) => (
                    <a
                      class="post-card"
                      href={post.href}
                      aria-label={`${post.title} 게시글 읽기`}
                      data-search={`${post.title} ${post.description} ${post.category}`}
                    >
                      <div class="post-meta">
                        <span>{post.category}</span>
                        <time datetime="2026-07-18">{post.date}</time>
                      </div>

                      <div class="card-icon" aria-hidden="true">
                        ⌘
                      </div>

                      <h4>{post.title}</h4>

                      <p>{post.description}</p>

                      <span class="read-more">
                        Read article
                        <span aria-hidden="true">→</span>
                      </span>
                    </a>
                  ))
                }
              </div>

              <p id="emptyMessage" class="empty-message" hidden>
                검색 결과가 없습니다.
              </p>
            </section>

            <section class="section" id="projects">
              <div class="section-heading">
                <div>
                  <span class="section-label">Work</span>
                  <h3>프로젝트</h3>
                </div>
              </div>

              <article class="project-card">
                <div>
                  <span class="project-status">In progress</span>
                  <h4>macOS GitHub Blog</h4>

                  <p>
                    Astro와 GitHub Pages를 이용해 만드는 macOS 감성의
                    개인 블로그입니다.
                  </p>
                </div>

                <span class="project-arrow" aria-hidden="true">↗</span>
              </article>
            </section>

            <section class="section" id="about">
              <div class="section-heading">
                <div>
                  <span class="section-label">About</span>
                  <h3>소개</h3>
                </div>
              </div>

              <article class="about-card">
                <div class="about-icon" aria-hidden="true">J</div>

                <div>
                  <h4>안녕하세요, hiJay97입니다.</h4>

                  <p>
                    개발 과정에서 배운 내용과 프로젝트 경험, 생산성 도구,
                    일상에 관한 생각을 기록합니다.
                  </p>
                </div>
              </article>
            </section>
          </section>
        </div>
      </main>
    </div>

    <script>
      const themeButton = document.querySelector(".theme-toggle");
      const searchInput = document.querySelector("#searchInput");
      const postCards = document.querySelectorAll(".post-card");
      const emptyMessage = document.querySelector("#emptyMessage");

      themeButton?.addEventListener("click", () => {
        document.documentElement.classList.toggle("light");

        const isLight =
          document.documentElement.classList.contains("light");

        try {
          localStorage.setItem("theme", isLight ? "light" : "dark");
        } catch {
          // localStorage를 사용할 수 없는 환경에서는 무시합니다.
        }
      });

      try {
        const savedTheme = localStorage.getItem("theme");

        if (savedTheme === "light") {
          document.documentElement.classList.add("light");
        }
      } catch {
        // localStorage를 사용할 수 없는 환경에서는 기본 다크 테마를 사용합니다.
      }

      searchInput?.addEventListener("input", (event) => {
        const input = event.currentTarget;

        if (!(input instanceof HTMLInputElement)) {
          return;
        }

        const keyword = input.value.trim().toLowerCase();
        let visibleCount = 0;

        postCards.forEach((card) => {
          if (!(card instanceof HTMLElement)) {
            return;
          }

          const searchText =
            card.dataset.search?.toLowerCase() ?? "";

          const isVisible = searchText.includes(keyword);

          card.hidden = !isVisible;

          if (isVisible) {
            visibleCount += 1;
          }
        });

        if (emptyMessage instanceof HTMLElement) {
          emptyMessage.hidden = visibleCount !== 0;
        }
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;

    --wallpaper: #090a0d;
    --wallpaper-accent: #26334a;
    --window: rgba(28, 29, 34, 0.88);
    --toolbar: rgba(38, 39, 45, 0.88);
    --sidebar: rgba(26, 27, 32, 0.72);
    --surface: rgba(255, 255, 255, 0.055);
    --surface-hover: rgba(255, 255, 255, 0.09);
    --border: rgba(255, 255, 255, 0.1);
    --border-strong: rgba(255, 255, 255, 0.17);
    --text: #f5f5f7;
    --secondary: #a1a1a6;
    --tertiary: #73737a;
    --accent: #0a84ff;
    --shadow: 0 40px 110px rgba(0, 0, 0, 0.52);
  }

  :root.light {
    color-scheme: light;

    --wallpaper: #dce7f4;
    --wallpaper-accent: #aebfd7;
    --window: rgba(246, 247, 250, 0.84);
    --toolbar: rgba(236, 237, 241, 0.9);
    --sidebar: rgba(225, 228, 234, 0.7);
    --surface: rgba(255, 255, 255, 0.6);
    --surface-hover: rgba(255, 255, 255, 0.82);
    --border: rgba(0, 0, 0, 0.1);
    --border-strong: rgba(0, 0, 0, 0.18);
    --text: #1d1d1f;
    --secondary: #5e5e63;
    --tertiary: #8a8a90;
    --accent: #0071e3;
    --shadow: 0 38px 100px rgba(43, 56, 77, 0.28);
  }

  * {
    box-sizing: border-box;
  }

  html {
    min-width: 320px;
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
    margin: 0;
    color: var(--text);
    background:
      radial-gradient(
        circle at 15% 0%,
        color-mix(
          in srgb,
          var(--wallpaper-accent) 80%,
          transparent
        ),
        transparent 34rem
      ),
      radial-gradient(
        circle at 95% 100%,
        rgba(98, 48, 118, 0.28),
        transparent 36rem
      ),
      var(--wallpaper);
    font-family:
      -apple-system,
      BlinkMacSystemFont,
      "SF Pro Display",
      "SF Pro Text",
      "Apple SD Gothic Neo",
      "Noto Sans KR",
      sans-serif;
    transition:
      color 180ms ease,
      background 180ms ease;
  }

  button,
  input {
    font: inherit;
  }

  button {
    color: inherit;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .desktop {
    min-height: 100vh;
    padding: clamp(18px, 4vw, 48px);
  }

  .window {
    width: min(1380px, 100%);
    min-height: calc(100vh - clamp(36px, 8vw, 96px));
    margin: 0 auto;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    border-radius: 24px;
    background: var(--window);
    box-shadow:
      var(--shadow),
      inset 0 1px rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(34px) saturate(140%);
    -webkit-backdrop-filter: blur(34px) saturate(140%);
  }

  .toolbar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    min-height: 56px;
    padding: 0 18px;
    border-bottom: 1px solid var(--border);
    background: var(--toolbar);
  }

  .traffic-lights {
    display: flex;
    gap: 8px;
  }

  .traffic {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    box-shadow: inset 0 -1px 1px rgba(0, 0, 0, 0.25);
  }

  .red {
    background: #ff5f57;
  }

  .yellow {
    background: #febc2e;
  }

  .green {
    background: #28c840;
  }

  .toolbar-title {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--secondary);
    font-size: 14px;
    font-weight: 600;
  }

  .folder-icon {
    font-size: 17px;
  }

  .theme-toggle {
    justify-self: end;
    width: 34px;
    height: 34px;
    border: 0;
    border-radius: 10px;
    background: transparent;
    cursor: pointer;
    transition:
      background 160ms ease,
      transform 160ms ease;
  }

  .theme-toggle:hover {
    background: var(--surface);
    transform: scale(1.04);
  }

  .theme-toggle:focus-visible,
  .navigation a:focus-visible,
  .post-card:focus-visible,
  .section-heading a:focus-visible,
  .sidebar-footer a:focus-visible {
    outline: 3px solid rgba(10, 132, 255, 0.45);
    outline-offset: 3px;
  }

  .window-body {
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr);
    min-height: calc(100vh - 153px);
  }

  .sidebar {
    display: flex;
    flex-direction: column;
    padding: 34px 20px 24px;
    border-right: 1px solid var(--border);
    background: var(--sidebar);
  }

  .profile {
    padding: 0 11px 32px;
  }

  .avatar {
    display: grid;
    width: 76px;
    height: 76px;
    place-items: center;
    margin-bottom: 18px;
    border: 1px solid var(--border-strong);
    border-radius: 22px;
    background:
      linear-gradient(
        145deg,
        rgba(255, 255, 255, 0.17),
        rgba(255, 255, 255, 0.025)
      ),
      #25272d;
    box-shadow:
      0 20px 38px rgba(0, 0, 0, 0.25),
      inset 0 1px rgba(255, 255, 255, 0.12);
    font-size: 32px;
    font-weight: 750;
  }

  .profile h1 {
    margin: 0;
    font-size: 26px;
    letter-spacing: -0.045em;
  }

  .profile p {
    margin: 8px 0 0;
    color: var(--secondary);
    font-size: 14px;
    line-height: 1.55;
  }

  .navigation {
    display: grid;
    gap: 5px;
  }

  .navigation a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 13px;
    border: 1px solid transparent;
    border-radius: 11px;
    color: var(--secondary);
    transition:
      color 160ms ease,
      background 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  .navigation a span {
    display: inline-grid;
    width: 23px;
    place-items: center;
    color: var(--tertiary);
    font-size: 18px;
  }

  .navigation a:hover {
    color: var(--text);
    background: var(--surface);
    transform: translateX(2px);
  }

  .navigation a.active {
    color: var(--text);
    border-color: rgba(10, 132, 255, 0.18);
    background: rgba(10, 132, 255, 0.17);
  }

  .navigation a.active span {
    color: var(--accent);
  }

  .sidebar-footer {
    margin-top: auto;
    padding: 20px 13px 0;
    color: var(--secondary);
    font-size: 13px;
  }

  .sidebar-footer a:hover {
    color: var(--accent);
  }

  .content {
    min-width: 0;
    padding: clamp(32px, 5vw, 72px);
  }

  .content-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 38px;
    margin-bottom: 56px;
  }

  .eyebrow,
  .section-label {
    color: var(--accent);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .content-header h2 {
    max-width: 760px;
    margin: 10px 0 16px;
    font-size: clamp(38px, 5.5vw, 72px);
    line-height: 0.98;
    letter-spacing: -0.065em;
  }

  .content-header p {
    max-width: 580px;
    margin: 0;
    color: var(--secondary);
    font-size: 16px;
    line-height: 1.65;
  }

  .search {
    display: flex;
    width: min(280px, 100%);
    flex: 0 0 auto;
    align-items: center;
    gap: 10px;
    padding: 10px 13px;
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--secondary);
    background: var(--surface);
    box-shadow: inset 0 1px rgba(255, 255, 255, 0.03);
  }

  .search:focus-within {
    border-color: rgba(10, 132, 255, 0.55);
    box-shadow: 0 0 0 3px rgba(10, 132, 255, 0.13);
  }

  .search input {
    width: 100%;
    min-width: 0;
    border: 0;
    outline: 0;
    color: var(--text);
    background: transparent;
  }

  .search input::placeholder {
    color: var(--tertiary);
  }

  .section {
    scroll-margin-top: 30px;
  }

  .section + .section {
    margin-top: 64px;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 22px;
  }

  .section-heading h3 {
    margin: 6px 0 0;
    font-size: 25px;
    letter-spacing: -0.035em;
  }

  .section-heading > a {
    color: var(--accent);
    font-size: 13px;
    font-weight: 600;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .post-card,
  .project-card,
  .about-card {
    border: 1px solid var(--border);
    border-radius: 18px;
    background:
      linear-gradient(
        145deg,
        rgba(255, 255, 255, 0.065),
        transparent
      ),
      rgba(20, 21, 25, 0.36);
    box-shadow: inset 0 1px rgba(255, 255, 255, 0.035);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .post-card {
    display: flex;
    min-height: 310px;
    flex-direction: column;
    padding: 25px;
    cursor: pointer;
  }

  .post-card:hover,
  .project-card:hover,
  .about-card:hover {
    transform: translateY(-3px);
    border-color: var(--border-strong);
    background: var(--surface-hover);
    box-shadow:
      inset 0 1px rgba(255, 255, 255, 0.055),
      0 18px 40px rgba(0, 0, 0, 0.14);
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    color: var(--tertiary);
    font-size: 12px;
  }

  .post-meta span {
    color: var(--accent);
    font-weight: 650;
  }

  .card-icon {
    display: grid;
    width: 46px;
    height: 46px;
    place-items: center;
    margin: 38px 0 24px;
    border: 1px solid var(--border);
    border-radius: 13px;
    background: var(--surface);
    color: var(--accent);
    font-size: 22px;
  }

  .post-card h4,
  .project-card h4,
  .about-card h4 {
    margin: 0;
    font-size: 22px;
    letter-spacing: -0.035em;
  }

  .post-card p,
  .project-card p,
  .about-card p {
    margin: 12px 0 28px;
    color: var(--secondary);
    font-size: 14px;
    line-height: 1.65;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-top: auto;
    color: var(--accent);
    font-size: 13px;
    font-weight: 650;
  }

  .post-card:hover .read-more span {
    transform: translateX(3px);
  }

  .read-more span {
    transition: transform 160ms ease;
  }

  .project-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 28px;
    padding: 26px;
  }

  .project-card p {
    max-width: 650px;
    margin-bottom: 0;
  }

  .project-status {
    display: inline-block;
    margin-bottom: 16px;
    color: #30d158;
    font-size: 12px;
    font-weight: 650;
  }

  .project-arrow {
    color: var(--secondary);
    font-size: 26px;
  }

  .about-card {
    display: flex;
    align-items: center;
    gap: 22px;
    padding: 26px;
  }

  .about-icon {
    display: grid;
    width: 58px;
    height: 58px;
    flex: 0 0 auto;
    place-items: center;
    border: 1px solid var(--border);
    border-radius: 17px;
    background: var(--surface);
    color: var(--accent);
    font-size: 23px;
    font-weight: 750;
  }

  .about-card p {
    max-width: 700px;
    margin-bottom: 0;
  }

  .empty-message {
    margin: 28px 0 0;
    padding: 28px;
    border: 1px dashed var(--border-strong);
    border-radius: 16px;
    color: var(--secondary);
    text-align: center;
  }

  [hidden] {
    display: none !important;
  }

  @media (max-width: 920px) {
    .window-body {
      grid-template-columns: 210px minmax(0, 1fr);
    }

    .content-header {
      display: grid;
      align-items: start;
    }

    .post-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .desktop {
      padding: 0;
    }

    .window {
      min-height: 100vh;
      border: 0;
      border-radius: 0;
    }

    .toolbar {
      min-height: 52px;
    }

    .window-body {
      display: block;
    }

    .sidebar {
      display: block;
      padding: 18px;
      border-right: 0;
      border-bottom: 1px solid var(--border);
    }

    .profile {
      display: grid;
      grid-template-columns: 58px 1fr;
      column-gap: 14px;
      padding: 0 2px 18px;
    }

    .avatar {
      grid-row: span 2;
      width: 58px;
      height: 58px;
      margin: 0;
      border-radius: 16px;
      font-size: 24px;
    }

    .profile h1 {
      align-self: end;
      font-size: 21px;
    }

    .profile p {
      align-self: start;
      margin-top: 2px;
    }

    .navigation {
      display: flex;
      overflow-x: auto;
      padding-bottom: 2px;
    }

    .navigation a {
      flex: 0 0 auto;
      white-space: nowrap;
    }

    .sidebar-footer {
      display: none;
    }

    .content {
      padding: 34px 20px 60px;
    }

    .content-header {
      margin-bottom: 44px;
    }

    .content-header h2 {
      font-size: clamp(38px, 14vw, 58px);
    }

    .search {
      width: 100%;
    }

    .post-card {
      min-height: 0;
    }

    .project-card,
    .about-card {
      align-items: flex-start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    *,
    *::before,
    *::after {
      transition: none !important;
    }
  }
</style>